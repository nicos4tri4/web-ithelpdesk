</div>

@code {
    private bool isSidebarOpen = true;
    private string CurrentUserName => (view == "admin_dashboard" || view == "pic_dashboard") ? (string.IsNullOrEmpty(loginUsername) ? "Staff" : loginUsername) : (string.IsNullOrEmpty(loggedInUserName) ? "User" : loggedInUserName);

    public void Dispose()
    {
        PresenceService.OnTicketPresenceChanged -= HandlePresenceChanged;
        PresenceService.OnNewTicketCreated -= HandleNewTicketCreated;
        if (selectedRequest != null)
        {
            PresenceService.LeaveTicket(selectedRequest.Id, CurrentUserName);
        }
    }

    private async void HandlePresenceChanged(string ticketId)
    {
        await InvokeAsync(StateHasChanged);
    }

    private async void HandleNewTicketCreated()
    {
        await InvokeAsync(async () => {
            LoadRequests();
            if (view == "admin_dashboard" || view == "pic_dashboard")
            {
                try 
                {
                    await JS.InvokeVoidAsync("eval", @"
                        (function() {
                            try {
                                var context = new (window.AudioContext || window.webkitAudioContext)();
                                var osc = context.createOscillator();
                                var gain = context.createGain();
                                osc.connect(gain);
                                gain.connect(context.destination);
                                osc.type = 'sine';
                                osc.frequency.setValueAtTime(880, context.currentTime);
                                osc.frequency.exponentialRampToValueAtTime(440, context.currentTime + 0.1);
                                gain.gain.setValueAtTime(0.5, context.currentTime);
                                gain.gain.exponentialRampToValueAtTime(0.01, context.currentTime + 0.5);
                                osc.start(context.currentTime);
                                osc.stop(context.currentTime + 0.5);
                            } catch(e) {}
                        })();
                    ");
                }
                catch { /* Ignore */ }
            }
            StateHasChanged();
        });
    }

    private void SetSelectedRequest(TicketRequest? req)
    {
        // leave current presence
        var currentName = CurrentUserName;
        if (selectedRequest != null)
        {
            PresenceService.LeaveTicket(selectedRequest.Id, currentName);
        }

        selectedRequest = req;
        
        // join new presence
        if (req != null)
        {
            PresenceService.JoinTicket(req.Id, currentName);
            if ((view == "admin_dashboard" || view == "pic_dashboard") && req.HasUnreadUserMessage)
            {
                req.HasUnreadUserMessage = false;
                DbContext.TicketRequests.Update(req);
                DbContext.SaveChanges();
            }
        }
    }

    private RenderFragment EmptyStateTemplate(string title, string message) => 
        @<tr>
            <td colspan="100" class="p-5 text-center">
                <div class="empty-state fade-in py-5">
                    <div class="empty-state-icon mb-4">
                        <svg width="100" height="100" viewBox="0 0 24 24" fill="none" stroke="url(#emptyGradient)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-75">
                            <defs>
                                <linearGradient id="emptyGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                                    <stop offset="0%" stop-color="#8ec5fc" />
                                    <stop offset="100%" stop-color="#e0c3fc" />
                                </linearGradient>
                            </defs>
                            <polyline points="22 12 16 12 14 15 10 15 8 12 2 12"></polyline>
                            <path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"></path>
                        </svg>
                    </div>
                    <h5 class="fw-bold mb-2" style="background: linear-gradient(90deg, #5B86E5, #36D1DC); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">@title</h5>
                    <p class="text-muted small mb-0">@message</p>
                </div>
            </td>
        </tr>;

    private string view = "public";
    private string loggedInUserName = "";
    private string activeTab = "queue";
    private string successMsg = "";
    private string formErrorMsg = "";
    private string loginError = "";
    private string loginUsername = "";
    private string loginPassword = "";

    private string adminTab = "queue";
    private TicketRequest formData = new TicketRequest { TargetDelivery = DateTime.Today.AddDays(1) };
    private List<TicketRequest> requests = new();
    private List<TeamMember> teamMembers = new();
    private TeamMember newTeamMember = new TeamMember();
    private Microsoft.AspNetCore.Components.Forms.IBrowserFile? uploadedFile;
    private TicketRequest? selectedRequest = null;
    private string newNote = "";
    private string? previewImageUrl = null;
    private bool isInitialLoading = true;
    private bool isSubmitting = false;
    private string searchQuery = "";
    private string? activeStatusFilter = null;
    private string activeViewType = "list";
    private DateTime currentMonth = DateTime.Today;
    private TicketRequest? draggedRequest;
    private string dragTargetStatus = "";
    private HashSet<string> collapsedColumns = new();
    private string swimlaneGroupBy = "None";
    private int wipLimitInProgress = 5;

    // Bulk Actions state
    private HashSet<string> selectedTicketIds = new();
    
    private void ToggleSelection(string id)
    {
        if (selectedTicketIds.Contains(id)) selectedTicketIds.Remove(id);
        else selectedTicketIds.Add(id);
    }
    
    private void ClearSelection() => selectedTicketIds.Clear();
    
    private void HandleBulkChangeStatus(string newStatus)
    {
        var toUpdate = DbContext.TicketRequests.Where(t => selectedTicketIds.Contains(t.Id)).ToList();
        foreach (var t in toUpdate) t.Status = newStatus;
        DbContext.SaveChanges();
        ClearSelection();
    }

    private void HandleBulkDelete()
    {
        var toDelete = DbContext.TicketRequests.Where(t => selectedTicketIds.Contains(t.Id)).ToList();
        DbContext.TicketRequests.RemoveRange(toDelete);
        DbContext.SaveChanges();
        ClearSelection();
    }

    private void ToggleColumn(string col)
    {
        if (collapsedColumns.Contains(col)) collapsedColumns.Remove(col);
        else collapsedColumns.Add(col);
    }

    private void HandleDragStart(TicketRequest request)
    {
        draggedRequest = request;
    }

    private void HandleDragEnter(string status)
    {
        dragTargetStatus = status;
    }

    private void HandleDragLeave()
    {
        dragTargetStatus = "";
    }

    private void HandleDrop(string newStatus)
    {
        if (draggedRequest != null)
        {
            draggedRequest.Status = newStatus;
            DbContext.SaveChanges();
            draggedRequest = null;
            dragTargetStatus = "";
        }
    }

    private string sortColumn = "CreatedAt";
    private bool sortAscending = false;

    private void SortBy(string column)
    {
        if (sortColumn == column)
        {
            sortAscending = !sortAscending;
        }
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
    }

    private string GetSortIcon(string column)
    {
        if (sortColumn != column) return "fas fa-sort text-muted ms-1 opacity-50";
        return sortAscending ? "fas fa-sort-up text-primary ms-1" : "fas fa-sort-down text-primary ms-1";
    }

    private IEnumerable<TicketRequest> GetFilteredRequests()
    {
        var res = requests.AsEnumerable();

        if (view == "pic_dashboard" && !string.IsNullOrEmpty(loginUsername))
        {
            res = res.Where(r => r.AssignedResource != null && r.AssignedResource.Split(',', StringSplitOptions.RemoveEmptyEntries).Any(p => string.Equals(p.Trim(), loginUsername, StringComparison.OrdinalIgnoreCase)));
        }

        if (activeStatusFilter != null)
        {
            if (activeStatusFilter == "Unassigned") res = res.Where(r => string.IsNullOrEmpty(r.AssignedResource));
            else res = res.Where(r => r.Status == activeStatusFilter);
        }

        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            var q = searchQuery.ToLower();
            res = res.Where(r => 
                r.Id.ToLower().Contains(q) || 
                r.RequesterName.ToLower().Contains(q) || 
                (r.Description != null && r.Description.ToLower().Contains(q)) ||
                (r.AssignedResource != null && r.AssignedResource.ToLower().Contains(q))
            );
        }
        
        var ordered = res;
        switch (sortColumn)
        {
            case "Id": ordered = sortAscending ? ordered.OrderBy(r => r.QueueNumber ?? r.Id) : ordered.OrderByDescending(r => r.QueueNumber ?? r.Id); break;
            case "Requester": ordered = sortAscending ? ordered.OrderBy(r => r.RequesterName) : ordered.OrderByDescending(r => r.RequesterName); break;
            case "TargetDate": ordered = sortAscending ? ordered.OrderBy(r => r.TargetDelivery) : ordered.OrderByDescending(r => r.TargetDelivery); break;
            case "PIC": ordered = sortAscending ? ordered.OrderBy(r => r.AssignedResource) : ordered.OrderByDescending(r => r.AssignedResource); break;
            case "Status": ordered = sortAscending ? ordered.OrderBy(r => r.Status) : ordered.OrderByDescending(r => r.Status); break;
            default: ordered = sortAscending ? ordered.OrderBy(r => r.CreatedAt) : ordered.OrderByDescending(r => r.CreatedAt); break;
        }
        return ordered;
    }

    private void ToggleFilter(string? status)
    {
        activeStatusFilter = status;
    }

    protected override async Task OnInitializedAsync()
    {
        PresenceService.OnTicketPresenceChanged += HandlePresenceChanged;
        PresenceService.OnNewTicketCreated += HandleNewTicketCreated;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            var name = authState.User.Identity.Name ?? "";
            loggedInUserName = name.Replace(@"PERTAMINA\", "");
            formData.RequesterName = loggedInUserName;
        }
        
        LoadRequests();
        
        // Auto-login PIC or Admin if the website knows the user
        if (!string.IsNullOrEmpty(loggedInUserName))
        {
            if (loggedInUserName.Equals("admin", StringComparison.OrdinalIgnoreCase) || 
                loggedInUserName.Equals("nico.amando", StringComparison.OrdinalIgnoreCase))
            {
                // Master admin
                loginUsername = loggedInUserName;
                view = "admin_dashboard";
                adminTab = "queue";
                activeViewType = "list";
            }
            else if (teamMembers != null && teamMembers.Any(tm => string.Equals(tm.Name, loggedInUserName, StringComparison.OrdinalIgnoreCase)))
            {
                var user = teamMembers.First(tm => string.Equals(tm.Name, loggedInUserName, StringComparison.OrdinalIgnoreCase));
                loginUsername = user.Name;
                
                // Route to admin portal if they have an admin-like role
                if (user.Role == "System Admin" || user.Role == "Admin" || user.Role == "Fullstack Developer")
                {
                    view = "admin_dashboard";
                }
                else
                {
                    view = "pic_dashboard";
                }
                
                adminTab = "queue";
                activeViewType = "list";
            }
        }

        isInitialLoading = true;
        await Task.Delay(1000); // Simulate network delay for skeleton effect
        isInitialLoading = false;
    }

