            await JS.InvokeVoidAsync("initTooltips");
            await JS.InvokeVoidAsync("initDragToScroll");
        }
        catch { /* Ignore if JS interop not ready */ }
    }

    private void LoadRequests()
    {
        requests = DbContext.TicketRequests.Include(r => r.FollowUpNotes).OrderByDescending(r => r.CreatedAt).ToList();
        teamMembers = DbContext.TeamMembers.ToList();
    }

    private async Task HandleTeamSubmit()
    {
        DbContext.TeamMembers.Add(newTeamMember);
        await DbContext.SaveChangesAsync();
        newTeamMember = new TeamMember();
        successMsg = "New PIC personnel successfully added!";
        LoadRequests();
    }

    private async Task HandleAssign(TicketRequest req, ChangeEventArgs e)
    {
        req.AssignedResource = e.Value?.ToString();
        DbContext.TicketRequests.Update(req);
        await DbContext.SaveChangesAsync();
        successMsg = "Successfully assigned resource!";
        LoadRequests();
    }

    private async Task HandleDeleteTeamMember(TeamMember tm)
    {
        DbContext.TeamMembers.Remove(tm);
        await DbContext.SaveChangesAsync();
        successMsg = $"Team member {tm.Name} deleted.";
        LoadRequests();
    }

    private async Task ToggleAssign(TicketRequest req, string picName)
    {
        var currentPics = string.IsNullOrEmpty(req.AssignedResource) 
            ? new List<string>() 
            : req.AssignedResource.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(p => p.Trim()).ToList();
        
        if (currentPics.Contains(picName, StringComparer.OrdinalIgnoreCase))
        {
            currentPics.RemoveAll(p => string.Equals(p, picName, StringComparison.OrdinalIgnoreCase));
        }
        else
        {
            currentPics.Add(picName);
        }
        
        req.AssignedResource = currentPics.Any() ? string.Join(", ", currentPics) : null;
        DbContext.TicketRequests.Update(req);
        await DbContext.SaveChangesAsync();
        successMsg = "Successfully updated resource assignment!";
        LoadRequests();
    }



    private async Task HandleDeleteRequest(TicketRequest req)
    {
        if (selectedRequest == req) selectedRequest = null;
        DbContext.TicketRequests.Remove(req);
        await DbContext.SaveChangesAsync();
        successMsg = "Request successfully deleted!";
        LoadRequests();
    }

    private async Task HandleSendNote()
    {
        if (selectedRequest != null && !string.IsNullOrWhiteSpace(newNote))
        {
            var note = new FollowUpNote
            {
                TicketRequestId = selectedRequest.Id,
                Note = newNote,
                Date = DateTime.UtcNow,
                SenderName = string.IsNullOrEmpty(loginUsername) ? selectedRequest.RequesterName : (view == "admin_dashboard" ? "Admin" : loginUsername)
            };
            DbContext.FollowUpNotes.Add(note);
            
            if (view == "public")
            {
                selectedRequest.HasUnreadUserMessage = true;
            }
            else
            {
                selectedRequest.HasUnreadUserMessage = false;
            }
            DbContext.TicketRequests.Update(selectedRequest);
            
            await DbContext.SaveChangesAsync();
            newNote = "";
            LoadRequests();
            
            // Re-bind selectedRequest to the updated one
            selectedRequest = requests.FirstOrDefault(r => r.Id == selectedRequest.Id);
        }
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        uploadedFile = e.File;
        formData.AttachmentName = uploadedFile.Name;
    }

    private async Task HandleSubmitRequest()
    {
        isSubmitting = true;
        StateHasChanged();
        await Task.Delay(800); // UI UX enhancement for feeling the process

        if (uploadedFile != null)
        {
            var uploadsPath = System.IO.Path.Combine(Env.WebRootPath, "uploads");
            System.IO.Directory.CreateDirectory(uploadsPath);
            
            var fileName = Guid.NewGuid().ToString() + System.IO.Path.GetExtension(uploadedFile.Name);
            var filePath = System.IO.Path.Combine(uploadsPath, fileName);
            
            using var fileStream = new System.IO.FileStream(filePath, System.IO.FileMode.Create);
            await uploadedFile.OpenReadStream(maxAllowedSize: 10485760).CopyToAsync(fileStream); // 10MB max
            
            formData.AttachmentUrl = "/uploads/" + fileName;
        }

        var totalCount = DbContext.TicketRequests.Count();
        formData.QueueNumber = $"TKT-{(totalCount + 1):D3}";

        DbContext.TicketRequests.Add(formData);
        await DbContext.SaveChangesAsync();
        PresenceService.NotifyNewTicket();
        
        formData = new TicketRequest { TargetDelivery = DateTime.Today.AddDays(1), RequesterName = loggedInUserName };
        uploadedFile = null;
        activeTab = "queue";
        successMsg = "Your request has been successfully submitted and added to the queue!";
        LoadRequests();
        isSubmitting = false;
    }

