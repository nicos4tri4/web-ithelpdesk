    private string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Waiting" => "bg-warning text-dark",
            "In Progress" => "bg-info text-dark",
            "Resolved" => "bg-success",
            "Closed" => "bg-secondary",
            _ => "bg-light text-dark border"
        };
    }


