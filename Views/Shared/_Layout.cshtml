<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HelpdeskApp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HelpdeskApp.styles.css" asp-append-version="true" />
    <base href="~/" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>
    <!-- Background Video (Removed to show image background) -->
    
    <div class="container-fluid p-0">
        <main role="main">
            @RenderBody()
        </main>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        window.initTooltips = () => {
            // Clean up ghost tooltips from Blazor re-renders
            var tooltips = document.querySelectorAll('.tooltip');
            tooltips.forEach(t => t.remove());

            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function (tooltipTriggerEl) {
                var inst = bootstrap.Tooltip.getInstance(tooltipTriggerEl);
                if(inst) inst.dispose();
                return new bootstrap.Tooltip(tooltipTriggerEl, { animation: true });
            });
        }
    </script>
    <div id="components-reconnect-modal" style="display: none !important;"></div>
    <script>
        window.addEventListener('DOMContentLoaded', () => {
            const modal = document.getElementById('components-reconnect-modal');
            if (!modal) return;

            let isDisconnected = false;

            const observer = new MutationObserver((mutations) => {
                const dot = document.getElementById('sync-indicator-dot');
                const text = document.getElementById('sync-indicator-text');
                const container = document.getElementById('sync-indicator-container');

                if (modal.classList.contains('components-reconnect-show') || 
                    modal.classList.contains('components-reconnect-failed') || 
                    modal.classList.contains('components-reconnect-rejected')) {
                    if (!isDisconnected) {
                        isDisconnected = true;
                        if (dot) dot.className = "bg-danger rounded-circle me-2";
                        if (text) {
                            text.innerText = "DISCONNECTED";
                            text.className = "small text-danger fw-bold";
                        }
                        if (container) container.title = "Connection to server lost. Reconnecting...";
                    }
                } else if (modal.classList.contains('components-reconnect-hide')) {
                    if (isDisconnected) {
                        isDisconnected = false;
                        if (dot) dot.className = "live-pulse bg-success rounded-circle me-2";
                        if (text) {
                            text.innerText = "LIVE SYNC";
                            text.className = "small text-secondary fw-bold";
                        }
                        if (container) container.title = "System is actively monitoring tickets";
                    }
                }
            });

            observer.observe(modal, { attributes: true, attributeFilter: ['class'] });
        });
    </script>
    <script src="_framework/blazor.server.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
